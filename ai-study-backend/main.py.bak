import os
import json
import asyncio
import google.auth 
from typing import AsyncGenerator
from fastapi import FastAPI, HTTPException
from fastapi.responses import StreamingResponse
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

# 2026년 기준 표준 Google GenAI SDK 사용
from google import genai
from google.genai import types

app = FastAPI(title="Study Gemini Automation Backend")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# [수정] google.auth 정상 동작
credentials, project_id = google.auth.default()
client = genai.Client(credentials=credentials)
PROMPT_FILE_PATH = "./study.gemini.md"

class ProjectGenerationRequest(BaseModel):
    project_goal: str
    language: str
    include_core: str
    file_name: str

def write_to_disk(path: str, content: str) -> str:
    """샌드박스 내부의 지정된 경로에 물리적으로 파일을 생성합니다."""
    try:
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, "w", encoding="utf-8") as f:
            f.write(content)
        return f"Success: {path} has been physically written to disk."
    except Exception as e:
        return f"Fail: Failed to write {path}. Error: {str(e)}"

async def generate_project_stream(req: ProjectGenerationRequest) -> AsyncGenerator[str, None]:
    if not os.path.exists(PROMPT_FILE_PATH):
        yield f"data: [MSG] ?? 시스템 에러: 마운트된 프롬프트 파일을 찾을 수 없습니다. 경로: {PROMPT_FILE_PATH}\n\n"
        return

    try:
        with open(PROMPT_FILE_PATH, "r", encoding="utf-8") as f:
            raw_prompt = f.read()
        
        system_instruction = (
            raw_prompt
            .replace("{{_project_goal}}", req.project_goal)
            .replace("{{_language}}", req.language)
            .replace("{{_include_core}}", req.include_core)
            .replace("{{_file_name}}", req.file_name)
        )
    except Exception as e:
        yield f"data: [MSG] ?? 프롬프트 파일 로드 중 실패: {str(e)}\n\n"
        return

    config = types.GenerateContentConfig(
        system_instruction=system_instruction,
        tools=[write_to_disk],
        temperature=0.2,
    )

    # 1. 멀티턴 대화를 추적하기 위한 메시지 히스토리 리스트 초기화
    conversation_contents = [
        types.Content(
            role="user",
            parts=[types.Part.from_text(text=f"프로젝트 명 '{req.project_goal}'에 대한 아키텍처 설계와 소스 코드 파일 생성을 시작해 주세요.")]
        )
    ]

    yield f"data: [ACT] ?? 디렉토리 구조 설계 및 보안 샌드박스 정렬 중...\n\n"
    await asyncio.sleep(0.1)
    yield f"data: [ACT] ?? 디렉토리 격리 완료 (기반 경로: ./output/{req.file_name})\n\n"

    try:
        # 2. 제미나이의 작업이 완전히 끝날 때까지 회전하는 오케스트레이션 루프
        while True:
            # 비동기 함수 내에서 블로킹을 방지하기 위해 client.aio 사용
            response_stream = await client.aio.models.generate_content_stream(
                model='gemini-3.1-pro-preview',
                contents=conversation_contents,
                config=config
            )

            text_buffer = ""
            tool_calls_this_turn = []
            tool_responses_this_turn = []
            has_function_call = False

            # 비동기 제너레이터를 순회하기 위해 async for 사용
            async for chunk in response_stream:
                # 완벽한 한 줄이 완성될 때만 분리해서 내보내는 텍스트 버퍼 알고리즘
                if chunk.text:
                    text_buffer += chunk.text
                    while "\n" in text_buffer:
                        line, text_buffer = text_buffer.split("\n", 1)
                        if line.strip():
                            yield f"data: {line}\n\n"
                
                # 이번 턴에 발생한 함수 호출 모아두기
                if chunk.function_calls:
                    has_function_call = True
                    for call in chunk.function_calls:
                        tool_calls_this_turn.append(call)
                        
                        target_path = call.args.get("path")
                        file_content = call.args.get("content")
                        
                        yield f"data: [ACT] ?? 파일 생성 중... -> {target_path}\n\n"
                        
                        # 동기 파일 입출력을 풀 안에서 안전하게 실행
                        loop = asyncio.get_running_loop()
                        result = await loop.run_in_executor(None, write_to_disk, target_path, file_content)
                        
                        if "Success" in result:
                            relative_path = target_path.replace(f"./output/{req.file_name}/", "")
                            yield f"data: [FILE] {relative_path}\n\n"
                        else:
                            yield f"data: [MSG] ?? 오류 발생: {result}\n\n"
                        
                        # 제미나이에게 돌려줄 실행 결과 파트 생성
                        tool_responses_this_turn.append(
                            types.Part(
                                function_response=types.FunctionResponse(
                                    name=call.name,
                                    response={"result": result}
                                )
                            )
                        )

            # 버퍼에 남아있는 텍스트 잔여분 처리
            if text_buffer.strip():
                yield f"data: {text_buffer}\n\n"

            # 더 이상 제미나이가 함수 호출을 하지 않으면 대화 엔진 종료
            if not has_function_call:
                break

            # 이번 턴에 수행한 모델의 호출 기록과 백엔드의 수행 결과를 히스토리에 차례로 병합
            model_turn_parts = [types.Part(function_call=call) for call in tool_calls_this_turn]
            
            # 선언되지 않은 model_parts 대신 model_turn_parts 사용
            conversation_contents.append(types.Content(role="model", parts=model_turn_parts))
            conversation_contents.append(types.Content(role="user", parts=tool_responses_this_turn))

        # 모든 멀티턴 시퀀스가 종료된 후 마감 핸드셰이크 송출
        yield f"data: [ACT] ? [작업 완료] 모든 파일이 성공적으로 빌드되었습니다.\n\n"

    except Exception as e:
        yield f"data: [MSG] ?? 시스템 에러 발생: {str(e)}\n\n"


@app.post("/api/generate-project")
async def generate_project(request: ProjectGenerationRequest):
    return StreamingResponse(
        generate_project_stream(request), 
        media_type="text/event-stream"
    )

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)